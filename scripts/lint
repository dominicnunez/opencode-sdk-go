#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")/.."

if ! command -v golangci-lint >/dev/null 2>&1; then
  echo "golangci-lint is required. Install: https://golangci-lint.run/welcome/install/"
  exit 1
fi

echo "==> Running Go build"
go build ./...

echo "==> Checking tests compile"
go test -run=^$ ./...

echo "==> Running golangci-lint"
golangci-lint run ./...
