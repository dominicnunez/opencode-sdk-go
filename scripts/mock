#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")/.."

PRISM_PID_FILE=".prism.pid"
STARTUP_POLL_INTERVAL_SECONDS="0.1"
STARTUP_TIMEOUT_SECONDS=30
STARTUP_MAX_ATTEMPTS=$((STARTUP_TIMEOUT_SECONDS * 10))

if [[ -n "${1:-}" && "${1:-}" != '--'* ]]; then
  URL="$1"
  shift
else
  URL="specs/openapi.yml"
fi

echo "==> Starting mock server with URL ${URL}"

# Run prism mock on the given spec
if [ "${1:-}" == "--daemon" ]; then
  rm -f "$PRISM_PID_FILE"
  npm exec --package=@stainless-api/prism-cli@5.15.0 -- prism mock "$URL" &> .prism.log &
  prism_pid=$!
  printf '%s\n' "$prism_pid" > "$PRISM_PID_FILE"

  # Wait for server to come online (timeout after 30s)
  echo -n "Waiting for server"
  iterations=0
  while ! grep -q "✖  fatal\|Prism is listening" ".prism.log" ; do
    if [ "$iterations" -ge "$STARTUP_MAX_ATTEMPTS" ]; then
      echo
      echo "Error: mock server failed to start within ${STARTUP_TIMEOUT_SECONDS} seconds"
      cat .prism.log
      kill "$prism_pid" 2>/dev/null || true
      rm -f "$PRISM_PID_FILE"
      exit 1
    fi
    echo -n "."
    sleep "$STARTUP_POLL_INTERVAL_SECONDS"
    iterations=$((iterations + 1))
  done

  if grep -q "✖  fatal" ".prism.log"; then
    cat .prism.log
    kill "$prism_pid" 2>/dev/null || true
    rm -f "$PRISM_PID_FILE"
    exit 1
  fi

  echo
else
  npm exec --package=@stainless-api/prism-cli@5.15.0 -- prism mock "$URL"
fi
